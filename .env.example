# Hashes SHA-256 (hex, minúsculo) dos tokens de acesso permitidos.
# Separe múltiplos tokens por vírgula.
#
# Como gerar o hash de um token no terminal:
#   node -e "crypto.subtle.digest('SHA-256', new TextEncoder().encode('SEU_TOKEN_AQUI')).then(h => console.log(Buffer.from(h).toString('hex')))"
#
# Configure esta variável em: Vercel → Project → Settings → Environment Variables
VITE_ALLOWED_TOKEN_HASHES=
